{
  "name": "sistema-rh-dre",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:api dev:web",
    "dev:api": "npm run dev --workspace apps/api",
    "dev:web": "npm run dev --workspace apps/web",
    "build": "npm run build --workspace apps/api && npm run build --workspace apps/web",
    "db:generate": "npm run prisma:generate --workspace apps/api",
    "db:push": "npm run prisma:push --workspace apps/api",
    "db:seed": "npm run prisma:seed --workspace apps/api"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
